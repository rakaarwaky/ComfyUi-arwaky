{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "comfyui-desktop",
  "version": "0.1.0",
  "identifier": "com.arwaky.comfyui",
  "build": {
    "frontendDist": "./assets/ui"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "ComfyUI Desktop",
        "width": 1600,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: http://127.0.0.1:8188 ws://127.0.0.1:8188; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8188 ws://127.0.0.1:8188 https://esm.sh; img-src 'self' data: blob: http://127.0.0.1:8188 https://*; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com",
      "capabilities": [
        {
          "identifier": "default",
          "description": "enables the default permissions",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "rpm", "deb"],
    "icon": [
      "assets/icons/32x32.png",
      "assets/icons/128x128.png",
      "assets/icons/128x128@2x.png",
      "assets/icons/icon.icns",
      "assets/icons/icon.ico"
    ]
  }
}
