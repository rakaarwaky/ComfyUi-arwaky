#!/usr/bin/env bash
# ==============================================================================
# comfyui-arwaky — Interactive Script Selector for ComfyUI Workspace
# ==============================================================================

# ANSI Color Codes
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color
BOLD='\033[1m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_FOLDER="$SCRIPT_DIR/scripts"

show_menu() {
    clear
    echo -e "${CYAN}┌────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│${NC}${BOLD}          ComfyUI-arwaky Script Selector Menu           ${NC}${CYAN}│${NC}"
    echo -e "${CYAN}└────────────────────────────────────────────────────────┘${NC}"
    echo -e "Please choose a script to execute:\n"
    
    echo -e " [1] ${GREEN}${BOLD}Start Standalone ComfyUI (Backend Only)${NC}"
    echo -e "     Run the ComfyUI backend server with AMD ROCm GPU acceleration."
    echo -e " [2] ${GREEN}${BOLD}Download Models Manager (TUI)${NC}"
    echo -e "     Open the interactive TUI downloader to manage and download models."
    echo -e " [3] ${GREEN}${BOLD}Run Symlink Watcher Service${NC}"
    echo -e "     Run the symlink monitor service to actively track file links."
    echo -e " [4] ${GREEN}${BOLD}Install App Binaries (Local Setup)${NC}"
    echo -e "     Install compiled binaries and generate local desktop shortcut."
    echo -e " [5] ${GREEN}${BOLD}Install Python Dependencies (Venv Setup)${NC}"
    echo -e "     Create Python 3.12 virtual environment and install requirements.txt."
    echo -e " [6] ${GREEN}${BOLD}Upgrade ROCm Libraries${NC}"
    echo -e "     Verify and upgrade ROCm libraries for PyTorch."
    echo -e " [7] ${GREEN}${BOLD}Build Desktop App & Downloader (Release)${NC}"
    echo -e "     Build the desktop launcher and model downloader release binaries."
    echo -e " [8] ${GREEN}${BOLD}Run Local CI Checks (Clippy & Format)${NC}"
    echo -e "     Run local CI checks (Rust format, clippy, tests, and shellcheck)."
    echo -e " [9] ${GREEN}${BOLD}Bump Project Version${NC}"
    echo -e "     Bump the project release version across the workspace."
    echo -e " [q] ${RED}Quit${NC}"
    echo -e "\n${CYAN}──────────────────────────────────────────────────────────${NC}"
}

while true; do
    show_menu
    read -rp "Enter your choice (1-9 or q): " pilihan
    
    case $pilihan in
        1)
            echo -e "\n${YELLOW}Starting ComfyUI Standalone Backend...${NC}"
            "$SCRIPTS_FOLDER/run_comfyui.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        2)
            echo -e "\n${YELLOW}Opening Model Downloader...${NC}"
            "$SCRIPTS_FOLDER/download_models.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        3)
            echo -e "\n${YELLOW}Running Symlink Watcher (press Ctrl+C to stop)...${NC}"
            "$SCRIPTS_FOLDER/watch-symlinks.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        4)
            echo -e "\n${YELLOW}Running Local Installer / Setup...${NC}"
            "$SCRIPTS_FOLDER/install_local.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        5)
            echo -e "\n${YELLOW}Installing Python Dependencies...${NC}"
            "$SCRIPTS_FOLDER/install_deps.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        6)
            echo -e "\n${YELLOW}Running ROCm Library Upgrade...${NC}"
            "$SCRIPTS_FOLDER/upgrade_rocm.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        7)
            echo -e "\n${YELLOW}Building Desktop App Launcher & Downloader...${NC}"
            "$SCRIPTS_FOLDER/build.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        8)
            echo -e "\n${YELLOW}Running Local CI Checks...${NC}"
            "$SCRIPTS_FOLDER/ci-local.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        9)
            echo -e "\n${YELLOW}Running Project Version Bump...${NC}"
            "$SCRIPTS_FOLDER/bump-version.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        [qQ])
            echo -e "\n${GREEN}Exiting. Goodbye!${NC}"
            exit 0
            ;;
        *)
            echo -e "\n${RED}Invalid choice!${NC}"
            sleep 1.5
            ;;
    esac
done
