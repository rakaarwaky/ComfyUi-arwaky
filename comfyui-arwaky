#!/usr/bin/env bash
# ==============================================================================
# comfyui-arwaky — Interactive Script Selector for ComfyUI Workspace
# ==============================================================================

# ANSI Color Codes
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color
BOLD='\033[1m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_FOLDER="$SCRIPT_DIR/scripts"

show_menu() {
    clear
    echo -e "${CYAN}┌────────────────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}│${NC}${BOLD}          ComfyUI-arwaky Script Selector Menu           ${NC}${CYAN}│${NC}"
    echo -e "${CYAN}└────────────────────────────────────────────────────────┘${NC}"
    echo -e ""
    echo -e " [1] ${GREEN}${BOLD}ComfyUI Backend Only${NC}"
    echo -e "     Run the ComfyUI backend server with AMD ROCm GPU acceleration."
    echo -e " [2] ${GREEN}${BOLD}ComfyUI Launcher${NC}"
    echo -e "     Open the Tauri desktop launcher application."
    echo -e " [3] ${GREEN}${BOLD}ComfyUI Download Manager${NC}"
    echo -e "     Open the interactive TUI downloader to manage and download models."
    echo -e " [4] ${GREEN}${BOLD}Build + Install Launcher Only${NC}"
    echo -e "     Build the desktop launcher (Tauri) and install to ~/.local/bin."
    echo -e " [5] ${GREEN}${BOLD}Build + Install Downloader (CLI + TUI)${NC}"
    echo -e "     Build the CLI + TUI model downloader and install to ~/.cargo/bin."
    echo -e " [6] ${GREEN}${BOLD}Install Python Dependencies (Venv Setup)${NC}"
    echo -e "     Create Python 3.12 virtual environment and install requirements.txt."
    echo -e " [7] ${GREEN}${BOLD}Upgrade ROCm Libraries${NC}"
    echo -e "     Verify and upgrade ROCm libraries for PyTorch."
    echo -e " [8] ${GREEN}${BOLD}Run CI Checks${NC}"
    echo -e "     Run fmt, clippy, test, shellcheck, and audit check."
    echo -e " [9] ${GREEN}${BOLD}Release Pipeline${NC}"
    echo -e "     CI → audit → bump → commit → push → tag → GitHub Release."
    echo -e " [10] ${GREEN}${BOLD}Run Symlink Watcher Service${NC}"
    echo -e "     Run the symlink monitor service to actively track file links."
    echo -e " [q] ${RED}Quit${NC}"
    echo -e "\n${CYAN}──────────────────────────────────────────────────────────${NC}"
}

while true; do
    show_menu
    read -rp "Enter your choice (1-10 or q): " pilihan

    case $pilihan in
        1)
            echo -e "\n${YELLOW}Starting ComfyUI Standalone Backend...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/run_comfyui.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        2)
            echo -e "\n${YELLOW}Opening ComfyUI Desktop Launcher...${NC}"
            cd "$SCRIPT_DIR" || exit
            if command -v comfyui-desktop &>/dev/null; then
                comfyui-desktop
            else
                echo -e "${RED}Launcher not installed. Build & install first (option 4).${NC}"
            fi
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        3)
            echo -e "\n${YELLOW}Opening Download Manager (TUI)...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/download_models.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        4)
            echo -e "\n${YELLOW}Building + Installing Launcher...${NC}"
            cd "$SCRIPT_DIR" || exit
            RUST_MIN_STACK=16777216 bash "$SCRIPTS_FOLDER/build-launcher.sh" && bash "$SCRIPTS_FOLDER/install_local.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        5)
            echo -e "\n${YELLOW}Building + Installing Downloader...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/build-downloader.sh" && bash "$SCRIPTS_FOLDER/install_local.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        6)
            echo -e "\n${YELLOW}Installing Python Dependencies...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/install_deps.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        7)
            echo -e "\n${YELLOW}Running ROCm Library Upgrade...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/upgrade_rocm.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        8)
            echo -e "\n${YELLOW}Running CI Checks...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/release.sh" --ci-only
            echo -e "\n${CYAN}Press any key to return to menu...${NC}"
            read -n 1 -s -r
            ;;
        9)
            echo -e "\n${YELLOW}Running release pipeline...${NC}"
            cd "$SCRIPT_DIR" || exit
            echo -e "  Auto-detecting version from Cargo.toml..."
            bash "$SCRIPTS_FOLDER/release.sh"
            echo -e "\n${CYAN}Press any key to return to menu...${NC}"
            read -n 1 -s -r
            ;;
        10)
            echo -e "\n${YELLOW}Running Symlink Watcher (press Ctrl+C to stop)...${NC}"
            cd "$SCRIPT_DIR" || exit
            bash "$SCRIPTS_FOLDER/watch-symlinks.sh"
            read -n 1 -s -r -p "Press any key to return to menu..."
            ;;
        [qQ])
            echo -e "\n${GREEN}Exiting. Goodbye!${NC}"
            exit 0
            ;;
        *)
            echo -e "\n${RED}Invalid choice!${NC}"
            sleep 1.5
            ;;
    esac
done
